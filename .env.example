# Configuração do banco de dados Supabase
# Obtenha a URL em: https://supabase.com/dashboard → Settings → Database → Connection string
#
# Use a "Transaction pooler" URL (porta 6543) para produção no Render:
# postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
#
# Ou a conexão direta (porta 5432) para uso local / migrations:
# postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

SESSION_SECRET=trocar-por-um-segredo-seguro
